rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profile Security Rules
    // - Authenticated users can read/write their own profile documents.
    // - Prevents users from reading or editing other users' profile documents.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Default fallback rule: deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
